# ----------------------------------------------------------------------------
# IGRE — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ----------------------------------------------------------------------------

# Database — SQLite file lives next to schema.prisma
DATABASE_URL="file:./igre.db"

# Auth.js v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Email (optional — leave blank to skip email sending; the app fails silently)
RESEND_API_KEY=""
EMAIL_FROM="IGRE <noreply@igre.ae>"

# WhatsApp — used to build wa.me deep links on the public site
NEXT_PUBLIC_WHATSAPP_NUMBER="971581005220"

# Upload limits
MAX_UPLOAD_SIZE_MB="5"

# In-memory rate limiter — swap to Redis (Upstash) in production
RATE_LIMIT_REQUESTS="10"
RATE_LIMIT_WINDOW_MS="60000"

# Seed script — sets the default password for all four staff accounts
# (forcePasswordChange is true so they must change it on first login)
SEED_DEFAULT_PASSWORD="IGRE@2026"
